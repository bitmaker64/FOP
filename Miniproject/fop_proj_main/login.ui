  <property name="styleSheet">
   <string notr="true">/* 1. A deep, dark background for the whole app */
QMainWindow {
    border-image: url(resources/bluebg.jpg);
}

/* 2. The Frosted Glass Box */
#login_box {
    background-color: rgba(255, 255, 255, 0.05); /* 5% white creates the glass */
    border: 1px solid rgba(255, 255, 255, 0.1);  /* Soft translucent border */
    border-radius: 20px;                         /* Apple's smooth corners */
}

/* 3. The Inputs */
QLineEdit {
    background-color: rgba(0, 0, 0, 0.3); /* Dark translucent inputs */
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    padding: 10px;
    color: white;
    font-size: 16px;
	font-weight: bold;
}
QLineEdit:focus {
    border: 1px solid #007AFF; /* Apple Blue glow */
}

/* 4. The Button */
QPushButton {
    background-color: #f59a62;
    color: white;
    border-radius: 10px;
    padding: 10px;
    font-weight: bold;
	font-size: 14px;
}
QPushButton:hover {
    background-color: #f08746;
}

QCheckBox{
	color: white;
	font-size: 12px;
}</string>
